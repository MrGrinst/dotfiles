#!/bin/bash

set -euo pipefail

readonly DEFAULT_BASE_BOOKMARKS=("dev" "main" "master")
readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly SESSION_BOOTSTRAP_COMMAND="${JJF_SESSION_BOOTSTRAP_COMMAND:-${SCRIPT_DIR}/jjf-sesh-bootstrap}"

source "${SCRIPT_DIR}/jj_helpers.sh"

usage() {
  cat <<'EOF'
Usage:
  jjf [name]

Starts a JJ feature workspace from a required name. The name can be temporary.
EOF
}

die() {
  echo "$*" >&2
  exit 1
}

require_command() {
  local command_name="$1"
  command -v "$command_name" >/dev/null 2>&1 || die "Missing prerequisite: $command_name"
}

fetch_origin_bookmarks() {
  local repo_root="$1"

  (
    cd "$repo_root"
    jj --quiet git fetch --remote origin >/dev/null
  )
}

read_recent_paths() {
  if command -v zoxide >/dev/null 2>&1; then
    zoxide query -l 2>/dev/null || true
  fi

  if [[ -f "${HOME}/.z" ]]; then
    cut -d'|' -f1 "${HOME}/.z" 2>/dev/null || true
  fi
}

is_base_repo_root() {
  local repo_root="$1"
  local workspace_root

  [[ -n "$repo_root" ]] || return 1
  workspace_root="$(jjf_workspace_root)"

  [[ "$repo_root" != "$workspace_root" && "$repo_root" != "$workspace_root"/* ]]
}

discover_repo_roots() {
  local current_root=""
  local candidate
  local repo_root

  current_root="$(jj root 2>/dev/null || true)"
  if is_base_repo_root "$current_root"; then
    printf '%s\n' "$current_root"
  fi

  while IFS= read -r candidate; do
    [[ -n "$candidate" && -d "$candidate" ]] || continue
    repo_root="$(cd "$candidate" && jj root 2>/dev/null || true)"
    is_base_repo_root "$repo_root" || continue
    printf '%s\n' "$repo_root"
  done < <(read_recent_paths)
}

pick_repo() {
  local repo_root

  repo_root="$(
    discover_repo_roots |
      awk 'NF && !seen[$0]++' |
      while IFS= read -r root; do
        printf '%s\t%s\n' "$(basename "$root")" "$root"
      done |
      fzf --with-nth=1,2 --delimiter=$'\t' --prompt='repo> ' --height=40% |
      cut -f2
  )"

  [[ -n "$repo_root" ]] || die "No repo selected."
  printf '%s\n' "$repo_root"
}

list_origin_bookmarks() {
  local repo_root="$1"
  local preferred=()
  local all_bookmarks
  local bookmark

  all_bookmarks="$(
    cd "$repo_root" &&
      jj bookmark list --remote origin --color=never -T 'if(remote == "origin", name ++ "\n", "")'
  )"

  for bookmark in "${DEFAULT_BASE_BOOKMARKS[@]}"; do
    if grep -qx "$bookmark" <<<"$all_bookmarks"; then
      preferred+=("$bookmark")
    fi
  done

  printf '%s\n' "${preferred[@]}"
  printf '%s\n' "$all_bookmarks" | awk 'NF && !seen[$0]++'
}

pick_base_bookmark() {
  local repo_root="$1"
  local base_bookmark

  base_bookmark="$(
    list_origin_bookmarks "$repo_root" |
      awk 'NF && !seen[$0]++' |
      fzf --prompt='base> ' --height=40%
  )"

  [[ -n "$base_bookmark" ]] || die "No base bookmark selected."
  printf '%s\n' "$base_bookmark"
}

prompt_name() {
  local name="${1:-}"

  while [[ -z "$name" ]]; do
    printf 'name> ' >&2
    read -r name
  done

  printf '%s\n' "$name"
}

maybe_add_to_zoxide() {
  local workspace_path="$1"

  if command -v zoxide >/dev/null 2>&1; then
    zoxide add "$workspace_path" >/dev/null 2>&1 || true
  fi
}

canonical_path() {
  local path="$1"

  (
    cd "$path"
    pwd -P
  )
}

tmux_has_session() {
  local target="$1"
  tmux has-session -t "=${target}" >/dev/null 2>&1
}

tmux_unique_session_name() {
  local base_name="$1"
  local candidate_name="$base_name"
  local suffix=2

  while tmux_has_session "$candidate_name"; do
    candidate_name="${base_name}-${suffix}"
    suffix=$((suffix + 1))
  done

  printf '%s\n' "$candidate_name"
}

tmux_session_for_workspace_path() {
  local workspace_path="$1"
  local workspace_raw_path="$1"
  local workspace_real_path
  local session_name
  local session_path
  local session_rows

  workspace_real_path="$(canonical_path "$workspace_path")"
  session_rows="$(tmux list-sessions -F '#{session_name}|#{session_path}' 2>/dev/null || true)"

  while IFS='|' read -r session_name session_path; do
    [[ -n "$session_name" && -n "$session_path" ]] || continue
    if [[ "$session_path" == "$workspace_raw_path" || "$session_path" == "$workspace_real_path" ]]; then
      printf '%s\n' "$session_name"
      return 0
    fi
  done <<<"$session_rows"

  return 1
}

attach_tmux_session() {
  local session_name="$1"

  if [[ -n "${TMUX:-}" ]]; then
    tmux switch-client -t "=${session_name}"
  else
    exec tmux attach-session -t "=${session_name}"
  fi
}

find_registered_workspace_path() {
  local repo_root="$1"
  local name="$2"
  local repo_name
  local workspace_path
  local slug

  repo_name="$(basename "$repo_root")"
  workspace_path="$(jjf_registry_lookup "$repo_name" "$name" 2>/dev/null || true)"
  if [[ -n "$workspace_path" && -d "$workspace_path" ]]; then
    printf '%s\n' "$(canonical_path "$workspace_path")"
    return 0
  fi

  slug="$(jjf_slugify "$name")"
  if [[ -n "$slug" ]]; then
    workspace_path="$(jjf_workspace_path_for_slug "$repo_name" "$slug")"
    if [[ -d "$workspace_path" ]]; then
      workspace_path="$(canonical_path "$workspace_path")"
      jjf_registry_set "$repo_name" "$name" "$workspace_path"
      printf '%s\n' "$workspace_path"
      return 0
    fi
  fi

  local expected_session_name
  local session_rows
  local session_name
  local session_path

  expected_session_name="$(jjf_workspace_session_name "$repo_name" "${slug:-$name}")"
  session_rows="$(tmux list-sessions -F '#{session_name}|#{session_path}' 2>/dev/null || true)"
  while IFS='|' read -r session_name session_path; do
    [[ -n "$session_name" && -n "$session_path" ]] || continue
    [[ "$session_name" == "$expected_session_name" ]] || continue
    [[ -d "$session_path" ]] || continue
    workspace_path="$(canonical_path "$session_path")"
    jjf_registry_set "$repo_name" "$name" "$workspace_path"
    printf '%s\n' "$workspace_path"
    return 0
  done <<<"$session_rows"

  return 1
}

create_workspace_session() {
  local session_name="$1"
  local workspace_path="$2"
  local desired_session_name

  desired_session_name="$session_name"
  if tmux_has_session "$desired_session_name"; then
    desired_session_name="$(tmux_unique_session_name "$desired_session_name")"
  fi

  tmux new-session -d -s "$desired_session_name" -c "$workspace_path" "$SESSION_BOOTSTRAP_COMMAND"
  attach_tmux_session "$desired_session_name"
}

connect_workspace() {
  local workspace_path="$1"
  local session_name="$2"
  local existing_session_name

  maybe_add_to_zoxide "$workspace_path"

  existing_session_name="$(tmux_session_for_workspace_path "$workspace_path" 2>/dev/null || true)"
  if [[ -n "$existing_session_name" ]]; then
    attach_tmux_session "$existing_session_name"
  else
    create_workspace_session "$session_name" "$workspace_path"
  fi
}

create_workspace() {
  local repo_root="$1"
  local base_bookmark="$2"
  local requested_name="$3"
  local workspace_path
  local workspace_name
  local bookmark_name
  local resolved_target
  local repo_name
  local session_name

  resolved_target="$(jjf_resolve_unique_target "$repo_root" "$requested_name")" || return 1
  IFS=$'\t' read -r bookmark_name workspace_name workspace_path <<<"$resolved_target"
  repo_name="$(basename "$repo_root")"
  session_name="$(jjf_workspace_session_name "$repo_name" "$workspace_name")"

  mkdir -p "$(jjf_workspace_root)"

  (
    cd "$repo_root"
    jj workspace add --name "$workspace_name" --revision "${base_bookmark}@origin" "$workspace_path"
  )

  (
    cd "$workspace_path"
    jj new @
    jj bookmark create "$bookmark_name" -r @
    jj describe -m "$requested_name"
  )

  workspace_path="$(canonical_path "$workspace_path")"
  jjf_registry_set "$repo_name" "$bookmark_name" "$workspace_path"
  connect_workspace "$workspace_path" "$session_name"
}

create_workspace_from_existing_bookmark() {
  local repo_root="$1"
  local bookmark_name="$2"
  local revision_spec="$3"
  local requested_name="${4:-$bookmark_name}"
  local workspace_path
  local workspace_name
  local resolved_target
  local repo_name
  local session_name

  resolved_target="$(jjf_resolve_existing_bookmark_target "$repo_root" "$bookmark_name" "$requested_name")" || return 1
  IFS=$'\t' read -r bookmark_name workspace_name workspace_path <<<"$resolved_target"
  repo_name="$(basename "$repo_root")"
  session_name="$(jjf_workspace_session_name "$repo_name" "$workspace_name")"

  mkdir -p "$(jjf_workspace_root)"

  (
    cd "$repo_root"
    jj workspace add --name "$workspace_name" --revision "$revision_spec" "$workspace_path"
  )

  (
    cd "$workspace_path"
    if ! jj_has_exact_local_bookmark "$bookmark_name"; then
      jj bookmark create "$bookmark_name" -r @
    fi
  )

  workspace_path="$(canonical_path "$workspace_path")"
  jjf_registry_set "$repo_name" "$bookmark_name" "$workspace_path"
  connect_workspace "$workspace_path" "$session_name"
}

main() {
  if [[ "${1:-}" == "-h" || "${1:-}" == "--help" || "${1:-}" == "help" ]]; then
    usage
    exit 0
  fi

  require_command fzf
  require_command jj
  require_command tmux

  local requested_name
  local repo_root
  local base_bookmark
  local existing_bookmark_target
  local existing_bookmark_name
  local existing_revision_spec
  local existing_workspace_path
  local existing_workspace_name
  local repo_name
  local session_name

  repo_root="$(pick_repo)"
  requested_name="$(prompt_name "${1:-}")"
  fetch_origin_bookmarks "$repo_root"
  repo_name="$(basename "$repo_root")"

  existing_bookmark_target="$(jjf_find_exact_bookmark "$repo_root" "$requested_name" || true)"
  if [[ -n "$existing_bookmark_target" ]]; then
    IFS=$'\t' read -r existing_bookmark_name existing_revision_spec <<<"$existing_bookmark_target"
    existing_workspace_path="$(find_registered_workspace_path "$repo_root" "$existing_bookmark_name" || true)"
    if [[ -z "$existing_workspace_path" && "$requested_name" != "$existing_bookmark_name" ]]; then
      existing_workspace_path="$(find_registered_workspace_path "$repo_root" "$requested_name" || true)"
    fi

    if [[ -n "$existing_workspace_path" ]]; then
      existing_workspace_path="$(canonical_path "$existing_workspace_path")"
      existing_workspace_name="$(jjf_slugify "$existing_bookmark_name")"
      [[ -n "$existing_workspace_name" ]] || existing_workspace_name="$(basename "$existing_workspace_path")"
      session_name="$(jjf_workspace_session_name "$repo_name" "$existing_workspace_name")"
      jjf_registry_set "$repo_name" "$existing_bookmark_name" "$existing_workspace_path"
      connect_workspace "$existing_workspace_path" "$session_name"
      exit 0
    fi

    create_workspace_from_existing_bookmark "$repo_root" "$existing_bookmark_name" "$existing_revision_spec" "$requested_name"
    exit 0
  fi

  base_bookmark="$(pick_base_bookmark "$repo_root")"

  create_workspace "$repo_root" "$base_bookmark" "$requested_name"
}

main "$@"
