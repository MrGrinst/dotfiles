#!/bin/sh

PATH="$HOME/.asdf/shims:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin:$PATH"
current_session_name="${1:-}"

tmux list-sessions -F '#{session_name}	#{session_alerts}' 2>/dev/null \
  | awk -F '\t' '
      $1 != current_session_name && $2 != "" {
        if (count > 0) {
          printf " "
        } else {
          printf "#[fg=colour255,bg=colour160,bold] bell: "
        }
        printf "%s", $1
        printf "[%s]", $2
        count++
      }
      END {
        if (count > 0) {
          printf " #[fg=colour2,bg=colour239,nobold]\n"
        }
      }
    ' current_session_name="$current_session_name"
